<%- include('./shared/navbar.ejs') %>


<div class="container text-center my-5">
    <div class="login-container">
        <div class="user my-3">
            <i class="fas fa-user-secret user-icon"></i>
            <h4 class="login">Login</h4>
        </div>
        <div class="card p-5 w-50 m-auto login-card">
            <form method="POST" action="/handleLogin">
                <% if (error && error.length) { %>
                    <div class="alert alert-danger alert-custom">
                        <% error.forEach(msg => { %>
                            <div><%= msg.message || msg %></div>
                        <% }) %>
                    </div>
                <% } %>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    </div>
                    <input class="form-control" placeholder="Enter your email" type="text" name="email" required>
                </div>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    </div>
                    <input class="form-control my-4 " placeholder="Enter your Password" type="password" name="password" required>
                </div>
                <button class="btn btn-default-outline my-4 w-100 rounded login-btn">Login</button>
                <a class="btn btn-default-outline" href="/register">Register</a>
            </form>
        </div>
    </div>
</div>
<%- include('./shared/footer.ejs') %>
