<%- include('./shared/navbar.ejs') %>

<div class="container text-center py-5 my-5 text-center">
    <div class="card pt-5">
        <a href="" data-toggle="modal" data-target="#profile">
            <img src="img/avatar.png" class="avatar " alt="">

        </a>
        <h3 class="py-2"><%= name %></h3>
        <button data-toggle="modal" data-target="#share" class="btn btn-default-outline share "><i class="fas fa-share-alt"></i>  Share Profile</button>
    </div>
</div>
<!-- profile photo Modal -->
<div class="modal fade" id="profile" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Change photo</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
            </div>
            <div class="modal-body">

                <div class="container">
                    <form action="" method="post">
                        <label for="" class="text-muted">The file size of the photo should not exceed 7 MB</label>
                        <input class="form-control" type="file" name="photo" id="">

                    </form>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-info">Upload</button>
                <button type="button" class="btn btn-outline-danger">Remove Photo</button>
            </div>
        </div>
    </div>
</div>

<!--  Share profile Modal -->
<div class="modal fade" id="share" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Share Profile</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
            </div>
            <div class="modal-body">
                <div class="share-link">
                    <label class="text-muted">Share this page:</label>
                    <a class="share-url" href="<%= profileLink %>" target="_blank" rel="noopener"><%= profileLink %></a>
                    <small class="share-note">Click the link or scan the QR code to send a message.</small>
                </div>
                <div class="qr-container">
                    <a href="<%= profileLink %>" target="_blank" rel="noopener">
                        <img src="<%= qrCode %>" alt="QR Code">
                    </a>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<!-- /modal -->



<!-- =================messages=================== -->
<div class="container text-center my-5 text-center">
    <div class="row">
        <% if (!messages || messages.length === 0) { %>
            <div class="col-md-12">
                <div class="card py-5 empty-card">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <p>You don't have any messages... </p>
                </div>
            </div>
        <% } else { %>
            <% messages.forEach((msg, i) => { %>
                <div class="col-md-12 mb-4">
                    <div class="card py-5 message-card">
                        <div class="message-content">
                            <i class="fas fa-quote-left quote-icon"></i>
                            <p class="message-text"><%= msg.message %></p>
                            <i class="fas fa-quote-right quote-icon"></i>
                        </div>
                        <div class="message-footer">
                            <small class="text-muted">Message <%= i + 1 %></small>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>
<%- include('./shared/footer.ejs') %>