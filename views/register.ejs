<%- include('./shared/navbar.ejs') %>

<div class="container text-center my-5">
    <div class="register-container">
        <div class="user my-3">
            <i class="far fa-edit user-icon"></i>
            <h4 class="login">Register</h4>
        </div>
        <div class="card p-5 w-50 m-auto register-card">
            <form method="POST" action="/handleRegister">
                <% if (error && error.length) { %>
                    <div class="alert alert-danger alert-custom">
                        <% error.forEach(msg => { %>
                            <div><%= msg.message || msg %></div>
                        <% }) %>
                    </div>
                <% } %>
                <% if (isExisted && isExisted.length) { %>
                    <div class="alert alert-danger alert-custom">
                        <%= isExisted[0] %>
                    </div>
                <% } %>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                    </div>
                    <input class="form-control" placeholder="Enter your Name" type="text" name="name" required>
                </div>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    </div>
                    <input class="form-control my-2 " placeholder="Enter your email" type="email" name="email" required>
                </div>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    </div>
                    <input class="form-control  " placeholder="Enter your Password" type="password" name="password" required>
                </div>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    </div>
                    <input class="form-control  my-2" placeholder="Password Confirmation" type="password" name="PasswordConfirmation" required>
                </div>
                <button class="btn btn-default-outline my-4 w-100 rounded register-btn">Register</button>
                <a class="btn btn-default-outline" href="/login">Login</a>
            </form>
        </div>
    </div>
</div>
<%- include('./shared/footer.ejs') %>